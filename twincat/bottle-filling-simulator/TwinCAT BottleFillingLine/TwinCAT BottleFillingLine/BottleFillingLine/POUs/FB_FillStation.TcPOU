<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.16">
  <POU Name="FB_FillStation" Id="{549dd795-e677-484a-9a04-53997ef36b6f}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_FillStation
VAR_INPUT
    Start         : BOOL;
    Stop          : BOOL;
    Hold          : BOOL;
    Abort         : BOOL;
	UnitState     : E_PackMLState;    // Added: wired from UnitSM.CurrentState in MAIN
END_VAR

VAR_OUTPUT
    Ready         : BOOL;
    Faulted       : BOOL;
    CurrentState  : E_PackMLState;
	FillLevel     : REAL;   // Simulates liquid fill level 0.0 to 100.0
END_VAR

VAR
    StateTimer    : TON;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[// Fill Station Module State Machine
// Simulates a liquid fill valve opening and filling bottles

IF Abort THEN
    CurrentState := E_PackMLState.Aborting;
    Ready        := FALSE;
END_IF

CASE CurrentState OF

    E_PackMLState.Undefined:
        CurrentState := E_PackMLState.Stopped;
        Ready        := FALSE;

    E_PackMLState.Stopped:
        Ready     := FALSE;
        FillLevel := 0.0;
        IF Start THEN
            CurrentState := E_PackMLState.Starting;
        END_IF

    E_PackMLState.Starting:
        // Simulate valve priming — 2 second startup
        Ready := FALSE;
        StateTimer(IN := TRUE, PT := T#2S);
        IF StateTimer.Q THEN
            StateTimer(IN := FALSE);
            CurrentState := E_PackMLState.Execute;
        END_IF

    E_PackMLState.Execute:
        // Simulate fill level rising each scan
        Ready     := TRUE;
        FillLevel := FillLevel + 0.5;
        IF FillLevel >= 100.0 THEN
            FillLevel := 0.0;   // Reset for next bottle
        END_IF
        IF Hold THEN
            CurrentState := E_PackMLState.Holding;
        ELSIF Stop THEN
            CurrentState := E_PackMLState.Stopping;
        END_IF

    E_PackMLState.Holding:
        Ready := FALSE;
        StateTimer(IN := TRUE, PT := T#1S);
        IF StateTimer.Q THEN
            StateTimer(IN := FALSE);
            CurrentState := E_PackMLState.Held;
        END_IF

    E_PackMLState.Held:
        Ready := FALSE;
        IF Start THEN
            CurrentState := E_PackMLState.Unholding;
        END_IF

    E_PackMLState.Unholding:
        StateTimer(IN := TRUE, PT := T#1S);
        IF StateTimer.Q THEN
            StateTimer(IN := FALSE);
            CurrentState := E_PackMLState.Execute;
        END_IF

    E_PackMLState.Stopping:
        Ready     := FALSE;
        FillLevel := 0.0;
        StateTimer(IN := TRUE, PT := T#2S);
        IF StateTimer.Q THEN
            StateTimer(IN := FALSE);
            CurrentState := E_PackMLState.Stopped;
        END_IF

    E_PackMLState.Aborting:
        Ready := FALSE;
        StateTimer(IN := TRUE, PT := T#500MS);
        IF StateTimer.Q THEN
            StateTimer(IN := FALSE);
            Faulted      := TRUE;
            CurrentState := E_PackMLState.Aborted;
        END_IF

    E_PackMLState.Aborted:
        Ready   := FALSE;
        Faulted := TRUE;

END_CASE]]></ST>
    </Implementation>
    <LineIds Name="FB_FillStation">
      <LineId Id="27" Count="85" />
      <LineId Id="9" Count="0" />
    </LineIds>
  </POU>
</TcPlcObject>